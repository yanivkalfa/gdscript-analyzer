{
  "//": "npm packaging for the napi-rs addon built from crates/gdscript-ffi. Per-platform `@gdscript-analyzer/core-<triple>` packages are wired as optionalDependencies (generated by `napi create-npm-dirs`); the loader index.js picks the right one at runtime.",
  "name": "@gdscript-analyzer/core",
  "version": "0.1.0",
  "description": "Headless GDScript (Godot 4.x) static analysis for Node — diagnostics, type-aware hover, completion, symbols, and navigation. The native binding of gdscript-analyzer (Roslyn for Godot).",
  "license": "(MIT OR Apache-2.0)",
  "author": "Yaniv Kalfa <yanivkalfa@gmail.com>",
  "homepage": "https://github.com/yanivkalfa/gdscript-analyzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanivkalfa/gdscript-analyzer.git",
    "directory": "bindings/node"
  },
  "keywords": ["gdscript", "godot", "godot-4", "analyzer", "static-analysis", "type-inference", "diagnostics", "completion", "lsp", "language-server", "napi"],
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=20" },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --manifest-path ../../crates/gdscript-ffi/Cargo.toml --output-dir .",
    "build:debug": "napi build --platform --manifest-path ../../crates/gdscript-ffi/Cargo.toml --output-dir .",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "demo": "node hello.mjs"
  },
  "devDependencies": { "@napi-rs/cli": "^3.2.0" },
  "private": false,
  "publishConfig": { "access": "public", "provenance": true },
  "files": ["index.js", "index.d.ts"],
  "napi": {
    "binaryName": "gdscript-analyzer",
    "packageName": "@gdscript-analyzer/core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  }
}
