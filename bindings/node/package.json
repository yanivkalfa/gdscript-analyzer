{
  "//": "Phase 0 scaffold. The napi-rs binding (crates/gdscript-ffi) is wired in Phase 1; this is where its .node addon is packaged + published. Per-platform `@gdscript-analyzer/core-<triple>` optionalDependencies are generated by `napi create-npm-dirs` in Phase 1.",
  "name": "@gdscript-analyzer/core",
  "version": "0.1.0",
  "description": "Node.js bindings for gdscript-analyzer — a fast, embeddable GDScript static-analysis library (Roslyn for Godot).",
  "license": "(MIT OR Apache-2.0)",
  "author": "Yaniv Kalfa <yanivkalfa@gmail.com>",
  "homepage": "https://github.com/yanivkalfa/gdscript-analyzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanivkalfa/gdscript-analyzer.git",
    "directory": "bindings/node"
  },
  "keywords": ["gdscript", "godot", "analyzer", "lsp", "language-server", "napi"],
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=20" },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --manifest-path ../../crates/gdscript-ffi/Cargo.toml --output-dir .",
    "build:debug": "napi build --platform --manifest-path ../../crates/gdscript-ffi/Cargo.toml --output-dir .",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "demo": "node hello.mjs"
  },
  "devDependencies": { "@napi-rs/cli": "^3.2.0" },
  "private": false,
  "publishConfig": { "access": "public", "provenance": true },
  "files": ["index.js", "index.d.ts"],
  "napi": {
    "binaryName": "gdscript-analyzer",
    "packageName": "@gdscript-analyzer/core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  }
}
